# ====================================================================
# Gitignore Global pour le dépôt CS:APP (S'applique à tous les sous-dossiers)
# ====================================================================

# --- Fichiers objets et binaires compilés ---
*.o
*.out
*.exe
*.a
*.so

# --- Exécutables spécifiques aux Labs ---
# Data Lab
btest
fshow
ishow

# Bomb Lab
bomb

# Attack Lab
ctarget
rtarget
hex2raw

# Cache Lab
csim
test-csim

# Shell Lab
tsh
myspin
mysplit
mystop
myint

# Malloc Lab
mdriver

# Proxy Lab
proxy

# --- Fichiers de log, traces et tests ---
*.log
.inputs
.outputs
tracebin/
driver.log

# --- Dumps système (Crash mémoire) ---
core
core.*
*.dSYM/
*.stackdump

# --- Archives brutes (Ne garde que tes dossiers extraits, ignore les zips d'origine) ---
*.tar
*.tar.gz
*.tgz
*.zip

# --- Fichiers temporaires et de configuration des éditeurs ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store